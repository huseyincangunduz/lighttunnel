# Proxy TCP bağlantısı — Client sunucusu
PROXY_HOST=proxy-host-ip-or-hostname
PROXY_TCP_PORT=14400

# TLS sertifikaları (mutual TLS için client sertifikası)
TLS_CA=infrastructure/certs/ca.crt
TLS_CERT=infrastructure/certs/client.crt
TLS_KEY=infrastructure/certs/client.key

# Bu client'ın kayıtlı servis adı
SERVICE_NAME=my-service
# Yerel backend
BACKEND_URL=http://localhost:5500
